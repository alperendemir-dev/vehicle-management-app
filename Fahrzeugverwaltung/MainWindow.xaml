<Window x:Class="Fahrzeugverwaltung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fahrzeugverwaltung" Height="560" Width="1000">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Eingaben -->
        <UniformGrid Rows="2" Columns="6" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Kennzeichen"/>
                <TextBox x:Name="TbKennzeichen" MinWidth="120"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Marke"/>
                <TextBox x:Name="TbMarke" MinWidth="120"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Modell"/>
                <TextBox x:Name="TbModell" MinWidth="140"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Kilometerstand"/>
                <TextBox x:Name="TbKm" MinWidth="100"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="TÜV-Datum"/>
                <DatePicker x:Name="DpTuv"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Preis (€)"/>
                <TextBox x:Name="TbPreis" MinWidth="100"/>
            </StackPanel>

            <Button Grid.Row="1" Content="Hinzufügen" Margin="0,8,8,0" Click="BtnAdd_Click"/>
            <Button Grid.Row="1" Content="Auswahl laden" Margin="0,8,8,0" Click="BtnLoadSelection_Click"/>
            <Button Grid.Row="1" Content="Änderungen speichern" Margin="0,8,8,0" Click="BtnSaveEdit_Click"/>
            <Button Grid.Row="1" Content="Löschen" Margin="0,8,8,0" Click="BtnDelete_Click"/>
            <Button Grid.Row="1" Content="Eingaben leeren" Margin="0,8,8,0" Click="BtnClear_Click"/>
            <Border Grid.Row="1"/>
            <!-- Platzhalter -->
        </UniformGrid>

        <!-- Liste -->
        <DataGrid x:Name="GridAutos"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kennzeichen" Binding="{Binding Kennzeichen}" Width="*" />
                <DataGridTextColumn Header="Marke"       Binding="{Binding Marke}" Width="*" />
                <DataGridTextColumn Header="Modell"      Binding="{Binding Modell}" Width="*" />
                <DataGridTextColumn Header="KM"          Binding="{Binding Kilometerstand}" Width="90" />
                <DataGridTextColumn Header="TÜV"         Binding="{Binding TuvDatum, StringFormat=\{0:dd.MM.yyyy\}}" Width="120"/>
                <DataGridTextColumn Header="Preis (€)"   Binding="{Binding Preis, StringFormat=\{0:N2\}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <DockPanel Grid.Row="2">
            <TextBlock x:Name="TxtStatus" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
        </DockPanel>
    </Grid>
</Window>
